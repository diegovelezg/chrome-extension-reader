{
  "manifest_version": 3,
  "name": "Cognitive Offload: Reader",
  "version": "1.0.0",
  "description": "Extract, summarize, and listen to webpage content with configurable LLM and TTS",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel", "webNavigation"],
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.ts"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}